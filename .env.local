# App
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5400/roleplay_app

# Logging
LOG_LEVEL=DEBUG

# Public URL of the frontend (SPA redirect after SSO sign-in). Also used as a CORS allowlist entry.
APP_URL=http://localhost:5173

# Auth
AUTH_PROTOCOL=oidc
JWT_SECRET=

# Default admin (created on first init)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Microsoft Entra ID - OIDC / SSO - set AUTH_PROTOCOL=oidc for these variables to be used
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#Issuer URL or full .well-known/openid-configuration URL
#OIDC_ISSUER_URL=
#OIDC_PROVIDER_NAME=
#OIDC_SCOPES=openid email profile
#OIDC_REDIRECT_URI=

# SAML / SSO — set AUTH_PROTOCOL=saml for these variables to be used
#SAML_PROVIDER_NAME=
#SAML_IDP_METADATA=
#SAML_ACS_URL=
#SAML_SP_ENTITY_ID=
#SAML_SP_CERT_DIR=data/saml

# Optional fallback LLM keys (prefer admin UI at /settings/ai)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=