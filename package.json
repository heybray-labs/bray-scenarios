{
  "name": "roleplay-standalone",
  "version": "1.0.6",
  "private": true,
  "type": "module",
  "description": "Standalone open-source roleplay training app",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "launch:local": "./bin/dev.sh",
    "db:push": "npm run db:push --workspace=server",
    "db:init": "npm run db:init --workspace=server",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "quickstart": "./bin/quickstart.sh",
    "quickstart:interactive": "./bin/quickstart.sh --interactive"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tsx": "^4.20.5"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
