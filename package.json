{
  "name": "roleplay-standalone",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "description": "Standalone open-source roleplay training app",
  "workspaces": [
    "client",
    "server",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "launch:local": "./bin/dev.sh",
    "db:push": "npm run db:push --workspace=server",
    "db:generate": "npm run db:generate --workspace=server",
    "db:migrate": "npm run db:migrate --workspace=server",
    "db:init": "npm run db:init --workspace=server",
    "db:seed-demo": "npm run db:seed-demo --workspace=server",
    "db:seed-demo:docker": "./bin/seed-demo-docker.sh",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "./bin/test.sh",
    "test:watch": "npm run test:watch --workspace=server",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v --remove-orphans",
    "docker:up": "./bin/compose-env.sh -- docker compose up --build",
    "docker:down": "./bin/compose-env.sh -- docker compose down",
    "docker:logs": "./bin/compose-env.sh -- docker compose logs -f app",
    "upgrade:backup": "./bin/upgrade-backup.sh",
    "upgrade:verify": "./bin/upgrade-verify.sh",
    "quickstart": "./bin/quickstart.sh",
    "quickstart:interactive": "./bin/quickstart.sh --interactive"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@heybray/gamification": "^1.0.0",
    "@heybray/identity": "^1.0.0",
    "@heybray/media": "^1.0.0",
    "concurrently": "^8.2.2",
    "tsx": "^4.20.5"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "guards-yalc-plant-test": "file:.yalc/@heybray/plant",
    "@heybray/gamification": "^1.0.0",
    "@heybray/gamification-react": "^1.2.0",
    "@heybray/identity": "^1.0.0",
    "@heybray/llm": "^1.0.0",
    "@heybray/media": "^1.0.0",
    "@heybray/react": "^1.1.0",
    "@heybray/server-kit": "^1.0.0",
    "@heybray/taxonomy": "^1.0.0",
    "@heybray/ui": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
