{
  "name": "roleplay-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../.env index.ts",
    "start": "node dist/index.js",
    "start:docker": "tsx index.ts",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts --force",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:init": "tsx --env-file=../.env init-db/init-db.ts",
    "db:seed-demo": "tsx --env-file=../.env init-db/seed-demo.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.5.1",
    "@langchain/core": "^1.2.1",
    "@langchain/google-genai": "^2.2.0",
    "@langchain/openai": "^1.5.3",
    "@node-saml/node-saml": "^5.1.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "multer": "^2.2.0",
    "nanoid": "^5.1.5",
    "openai": "^6.41.0",
    "openid-client": "^6.8.4",
    "pg": "^8.16.3",
    "selfsigned": "^5.5.0",
    "tsx": "^4.20.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.16.11",
    "@types/pg": "^8.15.5",
    "@types/selfsigned": "^2.0.4",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
