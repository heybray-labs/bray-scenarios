{
  "name": "roleplay-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../.env index.ts",
    "start": "node dist/index.js",
    "start:docker": "tsx index.ts",
    "typecheck": "tsc -p tsconfig.json",
    "db:push": "drizzle-kit push --config=drizzle.config.ts --force",
    "db:init": "tsx --env-file=../.env init-db/init-db.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.34",
    "@langchain/core": "^0.3.80",
    "@langchain/google-genai": "^0.1.12",
    "@langchain/openai": "^0.3.17",
    "@node-saml/node-saml": "^5.1.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.44.5",
    "drizzle-zod": "^0.7.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.3.37",
    "nanoid": "^5.1.5",
    "openai": "^5.19.0",
    "openid-client": "^6.8.4",
    "pg": "^8.16.3",
    "selfsigned": "^5.5.0",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.16.11",
    "@types/pg": "^8.15.5",
    "@types/selfsigned": "^2.0.4",
    "typescript": "^5.6.3"
  }
}
